{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": false,
    "composite": false,
    /* Fix for TS5096 */
    "allowImportingTsExtensions": false, 
    
    /* Strictness adjustments */
    "strict": true,
    "strictNullChecks": false, // This will solve the 'number | null' error in Filterbar
    
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts", 
    "src/**/*.d.ts", 
    "src/**/*.tsx", 
    "src/**/*.vue", 
    "env.d.ts",
    "src/shims-vue.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}